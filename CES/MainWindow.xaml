<Window x:Class="F1RaceEventConsumer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="F1 Race Event Consumer — SQL Server 2025 CES"
        Background="#0f0f1a"
        FontFamily="Consolas"
        WindowState="Maximized"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Banner -->
        <Border Grid.Row="0" Background="#E10600" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="F1 RACE EVENT CONSUMER"
                               FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="SQL Server 2025 Change Event Streaming Demo"
                               FontSize="12" Foreground="#FFCCCC" Margin="0,2,0,0"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="CES" FontSize="36" FontWeight="Bold"
                           Foreground="#33FFFFFF" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="1" Background="#16213e" Padding="24,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot" Width="10" Height="10"
                         Fill="#808080" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="ConnectionStatus" Text="Connecting..."
                           Foreground="#808080" VerticalAlignment="Center" FontSize="13"/>
                <Border Background="#2a2a4a" CornerRadius="3" Padding="8,3" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Race: " Foreground="#808080" FontSize="13"/>
                        <TextBlock x:Name="RaceStatusText" Text="Waiting"
                                   Foreground="White" FontWeight="Bold" FontSize="13"/>
                    </StackPanel>
                </Border>
                <Border Background="#2a2a4a" CornerRadius="3" Padding="8,3" Margin="12,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Events: " Foreground="#808080" FontSize="13"/>
                        <TextBlock x:Name="EventCountText" Text="0"
                                   Foreground="White" FontWeight="Bold" FontSize="13"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Event Feed -->
        <RichTextBox Grid.Row="2" x:Name="EventFeed"
                     Background="#0f0f1a" Foreground="White"
                     IsReadOnly="True" BorderThickness="0"
                     Padding="20,10" FontFamily="Consolas" FontSize="14"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled">
            <RichTextBox.Resources>
                <Style TargetType="Paragraph">
                    <Setter Property="Margin" Value="0,2,0,2"/>
                </Style>
            </RichTextBox.Resources>
            <FlowDocument x:Name="EventDocument" PageWidth="2000"/>
        </RichTextBox>

        <!-- Race Engineer Radio Panel -->
        <Border Grid.Row="3" x:Name="RadioPanel"
                Background="#1a1a00" BorderBrush="#FFD700"
                BorderThickness="0,2,0,0" Padding="24,14"
                Visibility="Collapsed">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="TEAM RADIO" FontWeight="Bold"
                               Foreground="#FFD700" FontSize="15"/>
                    <TextBlock Text=" — Race Engineer (AI)" Foreground="#CC9900" FontSize="15"/>
                </StackPanel>
                <TextBlock x:Name="RadioMessage" TextWrapping="Wrap"
                           Foreground="White" FontSize="14" Margin="0,0,0,6"/>
                <TextBlock Foreground="#666600" FontSize="11">
                    <Run Text="&#x25BA;"/>
                    <Run Text=" Sent to race-engineer-alerts queue"/>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
